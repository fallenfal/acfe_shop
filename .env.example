# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (dj-database-url format)
DATABASE_URL=postgres://acfe_user:acfe_password@localhost:5432/acfe_shop

# CORS (comma-separated origins; only if frontend is on another host)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production (Railway / VPS) — see DEPLOY_RAILWAY.md
# DEBUG=False
# ALLOWED_HOSTS=teamcafe.cloud,www.teamcafe.cloud
# CSRF_TRUSTED_ORIGINS=https://teamcafe.cloud,https://www.teamcafe.cloud
# PUBLIC_BASE_URL=https://teamcafe.cloud
# SEED_DEMO_DATA=true
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# JWT (optional; defaults: 60 minutes access, 7 days refresh)
# JWT_ACCESS_MINUTES=60
# JWT_REFRESH_DAYS=7

# Django admin superuser (created by: python manage.py ensure_superuser / seed_data)
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@acfe.coffee
# DJANGO_SUPERUSER_PASSWORD=admin2024!
